<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScreenTiger.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F12">

    <Grid Padding="24"
          BackgroundColor="#0F0F12">
        <Border
            BackgroundColor="#17171C"
            HorizontalOptions="Fill"
            Padding="20"
            Stroke="#3A3320"
            StrokeShape="RoundRectangle 18"
            VerticalOptions="Center">
            <VerticalStackLayout
                Spacing="14"
                VerticalOptions="Center"
                BackgroundColor="#17171C">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="128"
                    HorizontalOptions="Center"
                    Source="tigerlogo.png" />

                <Label
                    HorizontalOptions="Center"
                    SemanticProperties.HeadingLevel="Level1"
                    Text="ScreenTiger"
                    TextColor="#E6C76A" />

                <Label
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="Record your screen and package the result for AI review."
                    TextColor="#F5F2E8" />

                <Button
                    Clicked="OnStartRecordingClicked"
                    HorizontalOptions="Fill"
                    Text="Start Recording"
                    BackgroundColor="#17171C"
                    BorderColor="#D4AF37"
                    BorderWidth="1"
                    TextColor="#D4AF37" />

                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    Text="Microphone audio is included when permission is granted. Internal app audio is not captured."
                    TextColor="#C9C1AE" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
