<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScreenTiger.MainPage"
             BackgroundColor="#151325">

    <ScrollView>
        <Grid Padding="24">
            <Border
                BackgroundColor="#221F36"
                Stroke="#3B355C"
                StrokeThickness="1"
                Padding="24"
                VerticalOptions="Center"
                HorizontalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="14">
                    <Label
                        x:Name="PageTitleLabel"
                        Text="ScreenTiger"
                        FontSize="34"
                        FontAttributes="Bold"
                        TextColor="#F2EEFF"
                        SemanticProperties.HeadingLevel="Level1" />

                    <Label
                        x:Name="SubtitleLabel"
                        Text="Record your screen and package the result for AI review."
                        FontSize="16"
                        TextColor="#DDD4FF"
                        LineBreakMode="WordWrap" />

                    <Label
                        x:Name="BodyLabel"
                        Text=""
                        FontSize="14"
                        TextColor="#CFC7E6"
                        LineBreakMode="WordWrap" />

                    <ActivityIndicator
                        x:Name="StateActivityIndicator"
                        IsVisible="False"
                        IsRunning="False"
                        Color="#C8B5FF"
                        HorizontalOptions="Center" />

                    <Button
                        x:Name="PrimaryButton"
                        Text="Start Recording"
                        Clicked="OnPrimaryButtonClicked"
                        BackgroundColor="#C3AEFF"
                        TextColor="#22183D"
                        CornerRadius="12"
                        HeightRequest="52"
                        FontAttributes="Bold"
                        HorizontalOptions="Fill" />

                    <Button
                        x:Name="SecondaryButton"
                        IsVisible="False"
                        Clicked="OnSecondaryButtonClicked"
                        BackgroundColor="#2A2543"
                        TextColor="#E7DDFF"
                        BorderColor="#4A416E"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        HorizontalOptions="Fill" />

                    <Label
                        x:Name="MicrophoneNoteLabel"
                        Text="Microphone audio is included when permission is granted. Internal app audio is not captured."
                        FontSize="13"
                        TextColor="#C0B7DA"
                        LineBreakMode="WordWrap" />

                    <Label
                        x:Name="StatusLabel"
                        Text="Clean baseline ready."
                        FontSize="13"
                        TextColor="#E8DCFF"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>

</ContentPage>
