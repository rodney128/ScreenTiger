<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScreenTiger.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F12">

    <Grid Padding="24"
          BackgroundColor="#0F0F12">
        <Border
            BackgroundColor="#17171C"
            HorizontalOptions="Fill"
            Padding="20"
            Stroke="#3A3320"
            StrokeShape="RoundRectangle 18"
            VerticalOptions="Center">
            <VerticalStackLayout
                Spacing="14"
                VerticalOptions="Center"
                BackgroundColor="#17171C">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="128"
                    HorizontalOptions="Center"
                    Source="tigerlogo.png" />

                <Label
                    HorizontalOptions="Center"
                    SemanticProperties.HeadingLevel="Level1"
                    Text="ScreenTiger"
                    TextColor="#E6C76A" />

                <Label
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding TitleText}"
                    TextColor="#F5F2E8" />

                <Label
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding HasDetailText}"
                    LineBreakMode="WordWrap"
                    Text="{Binding DetailText}"
                    TextColor="#F5F2E8" />

                <ActivityIndicator
                    Color="#D4AF37"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusyState}"
                    IsVisible="{Binding IsBusyState}" />

                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding ShowMicrophoneStatus}"
                    Text="{Binding MicrophoneStatusText}"
                    TextColor="#C9C1AE" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      IsVisible="{Binding ShowDualActionButtons}">
                    <Button
                        Grid.Column="0"
                        Clicked="OnContinueClicked"
                        HorizontalOptions="Fill"
                        Text="Continue"
                        BackgroundColor="#17171C"
                        BorderColor="#D4AF37"
                        BorderWidth="1"
                        TextColor="#D4AF37" />

                    <Button
                        Grid.Column="1"
                        Clicked="OnCancelSetupClicked"
                        HorizontalOptions="Fill"
                        Text="Cancel"
                        BackgroundColor="#17171C"
                        BorderColor="#D4AF37"
                        BorderWidth="1"
                        TextColor="#D4AF37" />
                </Grid>

                <Button
                    Clicked="OnPrimaryActionClicked"
                    HorizontalOptions="Fill"
                    IsVisible="{Binding ShowPrimaryButton}"
                    IsEnabled="{Binding IsPrimaryButtonEnabled}"
                    Text="{Binding PrimaryButtonText}"
                    BackgroundColor="#17171C"
                    BorderColor="#D4AF37"
                    BorderWidth="1"
                    TextColor="#D4AF37" />

                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding ShowFooterMicrophoneNote}"
                    LineBreakMode="WordWrap"
                    Text="Microphone audio is included when permission is granted. Internal app audio is not captured."
                    TextColor="#C9C1AE" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
