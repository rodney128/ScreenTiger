<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScreenTiger.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PremiumBackground}">

    <Grid Padding="24">
        <Border
            BackgroundColor="{StaticResource PremiumSurface}"
            HorizontalOptions="Fill"
            Padding="20"
            Stroke="{StaticResource PremiumBorderMuted}"
            StrokeShape="RoundRectangle 18"
            VerticalOptions="Center">
            <VerticalStackLayout
                Spacing="14"
                VerticalOptions="Center">
                <Image
                    Aspect="AspectFit"
                    HeightRequest="128"
                    HorizontalOptions="Center"
                    Source="tigerlogo.png" />

                <Label
                    HorizontalOptions="Center"
                    SemanticProperties.HeadingLevel="Level1"
                    Style="{StaticResource Headline}"
                    Text="ScreenTiger"
                    TextColor="{StaticResource PremiumGoldSoft}" />

                <Label
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource SubHeadline}"
                    Text="Record your screen and package the result for AI review." />

                <Button
                    Clicked="OnStartRecordingClicked"
                    HorizontalOptions="Fill"
                    Text="Start Recording"
                    BackgroundColor="{StaticResource PremiumSurface}"
                    BorderColor="{StaticResource PremiumGold}"
                    BorderWidth="1"
                    TextColor="{StaticResource PremiumGold}" />

                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    Text="Microphone audio is included when permission is granted. Internal app audio is not captured."
                    TextColor="{StaticResource PremiumTextSecondary}" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
