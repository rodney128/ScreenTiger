<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScreenTiger.MainPage"
             BackgroundColor="#11111B">

    <Grid Padding="20">
        <Border
            BackgroundColor="#1E1E2E"
            StrokeThickness="0"
            Padding="20"
            VerticalOptions="Center"
            HorizontalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="14">
                <BoxView
                    HeightRequest="4"
                    WidthRequest="72"
                    HorizontalOptions="Start"
                    Color="#F4A261" />

                <Label
                    Text="ScreenTiger"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="#F8F8FF"
                    SemanticProperties.HeadingLevel="Level1" />

                <Label
                    Text="Record your Android screen and share the MP4 with ChatGPT for review."
                    FontSize="16"
                    TextColor="#D9D9E8"
                    LineBreakMode="WordWrap" />

                <Label
                    Text="Capture app issues, UI problems, and workflow bugs so they can be reviewed with an AI assistant or support person."
                    FontSize="14"
                    TextColor="#C6C6D6"
                    LineBreakMode="WordWrap" />

                <Button
                    Text="Start Recording"
                    Clicked="OnStartRecordingClicked"
                    BackgroundColor="#B79CFF"
                    TextColor="#1B1235"
                    CornerRadius="14"
                    HeightRequest="52"
                    FontAttributes="Bold"
                    HorizontalOptions="Fill" />

                <Label
                    x:Name="StatusLabel"
                    Text="Clean baseline ready."
                    FontSize="14"
                    TextColor="#E7E3FF"
                    LineBreakMode="WordWrap" />

                <Label
                    Text="Microphone permission will only be requested when recording starts. If permission is denied, ScreenTiger will continue video-only."
                    FontSize="13"
                    TextColor="#C9C9D8"
                    LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
